<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin CMS</title>
  <link rel="stylesheet" href="/home.css">
</head>
<body>
  <main>
    <h1>📊 Admin CMS</h1>

    <div class="admin-container">
      <h2>Add New Product</h2>
      <form action="/admin/add-product" method="POST" enctype="multipart/form-data">
        <input name="name" placeholder="Product name" required>
        <input name="price" type="number" placeholder="Price" required>
        <textarea name="description" placeholder="Product description"></textarea>
        <input type="file" name="image" accept="image/*">
        <button type="submit">✅ Add Product</button>
      </form>

      <div class="admin-products">
        <h2>📦 Products List</h2>
        <% if(products && products.length > 0) { %>
          <% products.forEach(p=>{ %>
            <div class="admin-product-item">
              <div>
                <% if(p.image){ %>
                  <img src="<%= p.image %>" width="50" style="border-radius: 4px; margin-right: 15px; vertical-align: middle;">
                <% } %>
                <strong><%= p.name %></strong> - $<%= p.price %>
              </div>
              <div>
                <a href="/admin/edit/<%= p.id %>" class="btn-link" style="padding: 5px 15px; font-size: 0.9em; margin-right: 10px;">✏️ Edit</a>
                <a href="/admin/delete/<%= p.id %>" class="btn-link" style="padding: 5px 15px; font-size: 0.9em;">🗑️ Delete</a>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p style="text-align: center; color: #7f8c8d;">No products yet</p>
        <% } %>
      </div>
    </div>

    <div class="nav-links">
      <a href="/">← Back to Store</a>
    </div>
  </main>
</body>
</html>